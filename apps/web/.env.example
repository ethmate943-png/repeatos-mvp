# Copy to .env and/or .env.local, then adjust.
# REPEATOS_ADMIN_API_KEY must match ADMIN_API_KEY in apps/api/.env

# Server-only: dashboard Server Components / server actions call the API here.
REPEATOS_API_URL=http://127.0.0.1:4000
REPEATOS_ADMIN_API_KEY=dev-admin-key

# Exposed to the browser (hosted menu /[slug], widget). Use the same public API URL as prod.
# On Koyeb: https://your-api-service.koyeb.app (no trailing slash)
NEXT_PUBLIC_REPEATOS_API_URL=http://127.0.0.1:4000

DASHBOARD_MODE=tenant
DEFAULT_BUSINESS_ID=11111111-1111-1111-1111-111111111111

# Showcase two demos:
# - Platform: DASHBOARD_MODE=platform (DEFAULT_BUSINESS_ID optional). Use ?business=<uuid> to switch.
# - Venue:    DASHBOARD_MODE=tenant + DEFAULT_BUSINESS_ID=<uuid> for one business only.
