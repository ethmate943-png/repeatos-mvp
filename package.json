{
  "name": "repeatos-mvp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd apps/widget && npm install && cd ../api && npm install",
    "heroku-postbuild": "cd apps/widget && npm run build",
    "build": "cd apps/widget && npm run build",
    "start": "cd apps/api && npx tsx src/server.ts",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed"
  },
  "engines": {
    "node": ">=20"
  }
}
